{
  "name": "car-library-api",
  "version": "1.0.0",
  "description": "Cloudflare Workers API for Car Library",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create car-library-db",
    "db:init": "wrangler d1 execute car-library-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute car-library-db --remote --file=./schema.sql"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "d1"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.57.1"
  },
  "dependencies": {
    "@cf-wasm/photon": "^0.3.4",
    "jose": "^6.2.2"
  }
}
